    "sass:build": "sass assets/scss/main.scss assets/css/main.css --no-source-map --silence-deprecation=import --silence-deprecation=if-function --silence-deprecation=global-builtin --silence-deprecation=color-functions",
    "sass:watch": "sass --watch assets/scss/main.scss assets/css/main.css --no-source-map --silence-deprecation=import --silence-deprecation=if-function --silence-deprecation=global-builtin --silence-deprecation=color-functions",
    "sass:build:min": "sass assets/scss/main.scss assets/css/main.min.css --style=compressed --no-source-map --silence-deprecation=import --silence-deprecation=if-function --silence-deprecation=global-builtin --silence-deprecation=color-functions"
  },
